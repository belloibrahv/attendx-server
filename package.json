{
  "name": "attendx-server",
  "version": "1.0.0",
  "description": "Backend API for AttendX - TASUED Smart Attendance System",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "build": "npx prisma generate",
    "setup": "chmod +x setup-db.sh && ./setup-db.sh",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate deploy",
    "test": "node test-server.js",
    "postinstall": "npx prisma generate",
    "render-build": "npm install && npx prisma generate"
  },
  "keywords": ["attendance", "education", "api", "nodejs", "prisma", "postgresql"],
  "author": "TASUED Development Team",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1006.0",
    "@aws-sdk/client-s3": "^3.1006.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "sharp": "^0.33.5",
    "uuid": "^13.0.0",
    "winston": "^3.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "nodemon": "^3.1.9",
    "typescript": "^5.7.2"
  }
}
